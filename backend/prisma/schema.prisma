datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

// 1. Tabel User
model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  password               String
  name                   String
  avatarUrl              String?                @map("avatar_url")
  isPremium              Boolean                @default(false) @map("is_premium")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  tags                   Tag[]     
  tagVotes               TagVote[] 
  profileSearchHistories ProfileSearchHistory[]

  @@map("users") 
}

// 2. Tabel Pusat Nomor Telepon
model PhoneNumber {
  id                     String                 @id @default(uuid())
  phoneNumber            String                 @unique @map("phone_number") 
  countryCode            String                 @map("country_code")
  searchCount            Int                    @default(0) @map("search_count")
  trustScore             Float                  @default(50.0) @map("trust_score")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  tags                   Tag[]    
  profileSearchHistories ProfileSearchHistory[]

  @@map("phone_numbers")
}

// 3. Tabel Tag dari Crowdsourcing
model Tag {
  id            String      @id @default(uuid())
  phoneNumberId String      @map("phone_number_id")
  phoneNumber   PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  userId        String?     @map("user_id") 
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  labelName     String      @map("label_name")
  upvotes       Int         @default(0)
  downvotes     Int         @default(0)
  isSpam        Boolean     @default(false) @map("is_spam")
  source        String      @default("USER_REPORT") // Menandai asal tag (USER_REPORT atau CONTACT_SYNC_LEGACY)
  createdAt     DateTime    @default(now()) @map("created_at")
  tagVotes      TagVote[]

  @@map("tags")
}

// 4. Tabel Log Vote untuk mencegah double voting
model TagVote {
  id        String   @id @default(uuid())
  tagId     String   @map("tag_id")
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voteType  VoteType @map("vote_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tagId, userId]) 
  @@map("tag_votes")
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

// 5. Tabel Log Pencarian Perangkat untuk Kuota Harian (Anti-Abuse)
model DeviceSearchLog {
  id          String   @id @default(uuid())
  deviceId    String   @map("device_id")
  dateString  String   @map("date_string") // e.g., "2026-07-14"
  searchCount Int      @default(1) @map("search_count")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([deviceId, dateString])
  @@map("device_search_logs")
}

// 6. Tabel Riwayat Pencarian Profil (Siapa Mencari Nomor Siapa + Data Retention Aggregation)
model ProfileSearchHistory {
  id              String      @id @default(uuid())
  searcherUserId  String?     @map("searcher_user_id") // ID pengguna yang mencari (jika login)
  searcherUser    User?       @relation(fields: [searcherUserId], references: [id], onDelete: SetNull)
  targetPhoneId   String      @map("target_phone_id")  // ID nomor telepon yang dicari/diperiksa
  targetPhone     PhoneNumber @relation(fields: [targetPhoneId], references: [id], onDelete: Cascade)
  searchCount     Int         @default(1) @map("search_count") // Agregasi frekuensi pencarian
  lastSearchedAt  DateTime    @default(now()) @map("last_searched_at")

  @@unique([searcherUserId, targetPhoneId])
  @@map("profile_search_histories")
}