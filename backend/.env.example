# Environment Variables Template for PhoneRep Check
# Copy this file to .env and fill in your actual connection string before running locally.

# PostgreSQL Connection URL (Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public)
DATABASE_URL="postgresql://postgres:password@localhost:5432/phonerep_db?schema=public"

# Application Port (Optional, default is 3000 for backend)
PORT=3000
