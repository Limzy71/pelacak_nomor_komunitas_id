# Environment Variables Template for PhoneRep Check
# Copy this file to .env and fill in your actual connection string before running locally.

# PostgreSQL Connection URL (Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public)
DATABASE_URL="postgresql://postgres:password@localhost:5432/phonerep_db?schema=public"

# Application Port (Optional, default is 3000 for backend)
PORT=3000

# WhatsApp OTP Gateway (Fonnte)
FONNTE_TOKEN="your-fonnte-token-here"

# Admin secret untuk endpoint DELETE /reset/:number
# WAJIB diisi — generate dengan: node -e "require('crypto').randomBytes(32).toString('hex')"
# JANGAN commit nilai asli ke version control
ADMIN_SECRET_KEY="your-strong-random-secret-min-32-chars"

# JWT secret untuk menandatangani token autentikasi pengguna
# WAJIB diisi — generate dengan: node -e "require('crypto').randomBytes(48).toString('hex')"
# JANGAN commit nilai asli ke version control
JWT_SECRET="your-strong-random-jwt-secret-min-48-chars"
